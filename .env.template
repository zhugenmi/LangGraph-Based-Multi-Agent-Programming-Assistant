# Default Model API Configuration
# 默认模型配置，所有 Agent 都会使用此配置作为回退
DEFAULT_MODEL=
DEFAULT_MODEL_API_KEY=
DEFAULT_MODEL_BASE_URL=

# Agent-specific Model Configuration (optional)
# Agent 专用模型配置（可选）
# 规则：
#   1. 如果某项配置为空，自动使用 DEFAULT_*配置作为回退
#   2. 如果只配置了 MODEL 名称，API_KEY 和 BASE_URL 为空，也会使用 DEFAULT 配置
#   3. 支持为不同 Agent 配置不同的模型、API 密钥和 Base URL

# Supervisor Agent - 负责任务规划和分解
SUPERVISOR_MODEL=
SUPERVISOR_MODEL_API_KEY=
SUPERVISOR_MODEL_BASE_URL=

# Repo Analyst Agent - 负责代码库分析
REPO_ANALYST_MODEL=
REPO_ANALYST_MODEL_API_KEY=
REPO_ANALYST_MODEL_BASE_URL=

# Implementer Agent - 负责代码生成和修复
IMPLEMENTER_MODEL=
IMPLEMENTER_MODEL_API_KEY=
IMPLEMENTER_MODEL_BASE_URL=

# Reviewer Agent - 负责代码审查
REVIEWER_MODEL=
REVIEWER_MODEL_API_KEY=
REVIEWER_MODEL_BASE_URL=

# Tester Agent - 负责测试生成和执行
TESTER_MODEL=
TESTER_MODEL_API_KEY=
TESTER_MODEL_BASE_URL=

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
# 是否使用 Redis 存储会话数据（true=Redis，false=文件存储）
USE_REDIS=false

# MCP Client Configuration
MCP_SERVER_URL=http://localhost:8000
# MCP API 密钥，用于验证 MCP 客户端身份
MCP_API_KEY=your_mcp_api_key

# Project Settings
PROJECT_NAME=LangGraph-Based Multi-Agent Programming Assistant
DEBUG=True

# ==================== RAG Configuration ====================
# Embedding模型配置

# 使用本地向量模型（true=使用本地模型，false=使用 API 调用）
USE_LOCAL_EMBEDDING=true

# 模型名称
EMBEDDING_MODEL=text-embedding-ada-002

# API请求地址（必填）
# 本地Ollama: http://localhost:11434
# OpenAI: https://api.openai.com/v1
# 阿里云DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_BASE_URL=http://localhost:11434

# API密钥（本地Ollama可能不需要，远程API需要）
EMBEDDING_MODEL_API_KEY=

# 向量维度（根据模型选择）
# bge-m3: 1024, text-embedding-ada-002: 1536
EMBEDDING_DIMENSION=1024

# 代码分块配置
CODE_CHUNK_SIZE=500
CODE_CHUNK_OVERLAP=50

# RAG索引存储目录
RAG_INDEX_DIR=rag_index
RAG_STORAGE_DIR=memory_store

# RAG文件过滤
# 要索引的文件扩展名 (逗号分隔)
RAG_FILE_EXTENSIONS=.py,.js,.ts,.jsx,.tsx,.md,.txt,.json,.yaml,.yml,.toml,.java,.cpp,.c,.go,.rs,.rb,.php,.swift,.kt,.sh,.sql
# 要排除的目录 (逗号分隔)
RAG_EXCLUDE_DIRS=.git,__pycache__,node_modules,venv,.venv,.env,dist,build,.cache
